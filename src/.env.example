# GeoBox Environment Configuration

# Azure OpenAI (required for validation agent and orchestrator)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Week 3: MCP Server URLs
# For local development use localhost; for Azure Container Apps use internal hostnames

# ExifTool MCP Server (GPS extraction)
# Local: http://localhost:8081/sse  |  Azure: http://geobox-mcp-exiftool-dev/sse
MCP_EXIFTOOL_URL=http://localhost:8081/sse

# Geospatial MCP Server (reverse geocoding, elevation, land/water)
# Local: http://localhost:8082  |  Azure: http://geobox-mcp-geo-dev:8082
GEO_SERVER_URL=http://localhost:8082

# Box Configuration (handled via config.json - keep this for reference)
# BOX_CONFIG_PATH=./config/box_config.json

# Logging
LOG_LEVEL=INFO

# The app auto-detects mode: uses Agent Framework when Azure OpenAI is configured,
# falls back to direct extraction agent otherwise.
