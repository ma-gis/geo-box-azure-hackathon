# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Box Configuration
# Local dev: set BOX_CONFIG_PATH to the JWT config file
BOX_CONFIG_PATH=./config/box_config.json
# Production: set BOX_CONFIG_JSON to the full JSON string (takes priority over BOX_CONFIG_PATH)
# BOX_CONFIG_JSON={"boxAppSettings":{"clientID":"...","clientSecret":"...","appAuth":{...}},...}
BOX_METADATA_TEMPLATE=geoBoxIntelligence
BOX_WEBHOOK_SIGNATURE_KEY=

# Application Settings
APP_NAME=GeoBox
LOG_LEVEL=INFO
